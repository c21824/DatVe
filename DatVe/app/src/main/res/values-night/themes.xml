<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.DatVe" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryVariant">@color/md_primary_variant</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="android:colorBackground">@color/md_background</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.DatVe.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.DatVe.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.DatVe.Large</item>
    </style>
</resources>